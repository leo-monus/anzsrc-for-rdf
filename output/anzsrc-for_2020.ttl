    dcterms:issued "2020-06-30"^^xsd:date ;
    dcterms:title "1297.0 ANZSRC - Australian and New Zealand Standard Research Classification, 2020: Fields of Research (FoR)"@en ;
    skos:hasTopConcept <https://linked.data.gov.au/def/anzsrc-for/2020/30>,
        <https://linked.data.gov.au/def/anzsrc-for/2020/31>,
        <https://linked.data.gov.au/def/anzsrc-for/2020/32>,
        <https://linked.data.gov.au/def/anzsrc-for/2020/33>,
