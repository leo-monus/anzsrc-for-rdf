<https://linked.data.gov.au/def/anzsrc-for/2020/3108> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-for/2020/31> ;
    skos:definition """This group covers plant biology.
It includes:
• plant pathology other than that associated with plant protection procedures used in agriculture and horticulture; and
• phycology (including algae and marine grasses)."""@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-for/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-for/2020/310801>,
