<https://linked.data.gov.au/def/anzsrc-for/2020/4017> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-for/2020/40> ;
    skos:definition "This group covers mechanical engineering."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-for/2020> ;
