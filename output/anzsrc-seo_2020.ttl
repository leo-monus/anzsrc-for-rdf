<https://linked.data.gov.au/def/anzsrc-seo/2020/2005> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/20> ;
    skos:definition "This group covers R&D directed towards community and public health of specific population groups and discrete community groups (e.g. aged persons, persons living in rural and remote areas), other than indigenous communities. It includes the study of social and cultural factors affecting the health of these groups and the delivery of health services to these groups."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-seo/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-seo/2020/200501>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/200502>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/200503>,
