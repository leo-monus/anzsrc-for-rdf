<https://linked.data.gov.au/def/anzsrc-seo/2020/2202> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/22> ;
    skos:definition "This group covers R&D directed towards environmentally sustainable ways of managing information and communication service activities by minimising the generation of emissions and wastes and by reducing or optimising the consumption of water and other natural resources."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-seo/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-seo/2020/220201>,
