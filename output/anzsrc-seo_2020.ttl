<https://linked.data.gov.au/def/anzsrc-seo/2020/2416> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/24> ;
    skos:definition """This group covers R&D directed towards the manufacture of pharmaceutical products used in the
prevention, diagnosis and treatment of veterinary diseases."""@en ;
