    skos:notation "2405" ;
    skos:prefLabel "Dairy products"@en .

<https://linked.data.gov.au/def/anzsrc-seo/2020/2406> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/24> ;
    skos:definition "This group covers R&D directed towards environmentally sustainable production of manufactured materials by minimising the generation of emissions and wastes and by reducing or optimising the consumption of water and other natural resources."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-seo/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-seo/2020/240601>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/240602>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/240603>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/240604>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/240605>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/240699> ;
    skos:notation "2406" ;
    skos:prefLabel "Environmentally sustainable manufacturing activities"@en ;
    skos:scopeNote """a) Minimisation of input waste (other than water and energy) is to be categorised according to the objective that benefits from the improvement of input use.
b) Energy conservation and efficiency in manufacturing processes is included in Group 1701 Energy efficiency.
c) Industrial processing of wastes and scrap to manufacture new products is included in the appropriate groups in Division 24 Manufacturing.
d) Waste handling services such as collection, storage, recycling and disposal provided by local councils or private or non-profit waste management businesses are included in Group 1105 Water and waste services.
e) Air quality; control of pests, diseases and exotic species; ecosystem assessment and management; flora, fauna and biodiversity; land and water management; rehabilitation of degraded areas; remnant vegetation and conservation areas; soils; and natural hazards in urban and industrial environments or other environments affected by manufacturing activities are included in Divisions 18 Environmental management and 19 Environmental policy, climate change and natural hazards."""@en .

<https://linked.data.gov.au/def/anzsrc-seo/2020/2412> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/24> ;
    skos:definition "This group covers R&D directed towards the manufacture of machinery and equipment. It includes household electrical appliances and whitewares."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-seo/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-seo/2020/241201>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241202>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241203>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241204>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241205>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241299> ;
    skos:notation "2412" ;
    skos:prefLabel "Machinery and equipment"@en ;
    skos:scopeNote "a) Computers and electronic equipment, including consumer electronic equipment, is included in Group 2404 Computer, electronic and communication equipment."@en .

<https://linked.data.gov.au/def/anzsrc-seo/2020/2417> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/24> ;
    skos:definition "This group covers R&D directed towards the processing of wood, and the manufacture of wood products, paper and paper products."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-seo/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-seo/2020/241701>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241702>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/241703>,
