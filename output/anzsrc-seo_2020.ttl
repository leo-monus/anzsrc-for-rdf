    dcterms:issued "2020-06-30"^^xsd:date ;
    dcterms:title "1297.0 ANZSRC - Australian and New Zealand Standard Research Classification, 2020: Socio-Economic Objectives (SEO)"@en ;
    skos:hasTopConcept <https://linked.data.gov.au/def/anzsrc-seo/2020/10>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/11>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/12>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/13>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/14>,
        <https://linked.data.gov.au/def/anzsrc-seo/2020/15>,
