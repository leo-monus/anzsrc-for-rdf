<https://linked.data.gov.au/def/anzsrc-seo/2020/2403> a skos:Concept ;
    skos:broader <https://linked.data.gov.au/def/anzsrc-seo/2020/24> ;
    skos:definition "This group covers R&D directed towards the manufacture of ceramics, glass and glass products and industrial mineral products, including clay, cement and concrete products. It includes R&D directed towards the manufacture of plaster and non-metallic mineral products."@en ;
    skos:inScheme <https://linked.data.gov.au/def/anzsrc-seo/2020> ;
    skos:narrower <https://linked.data.gov.au/def/anzsrc-seo/2020/240301>,
