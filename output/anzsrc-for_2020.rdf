    <skos:prefLabel xml:lang="en">Mechanical engineering not elsewhere classified</skos:prefLabel>
    <skos:notation>401799</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-for/2020/4017">
        <skos:prefLabel xml:lang="en">Mechanical engineering</skos:prefLabel>
        <skos:notation>4017</skos:notation>
