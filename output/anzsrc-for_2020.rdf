        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5106"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5107"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5108"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5109"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5110"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5199"/>
      </skos:Concept>
    </skos:broader>
    <skos:definition xml:lang="en">This group covers condensed matter physics.</skos:definition>
    <skos:scopeNote xml:lang="en">a) Other material sciences are included in Groups 3402 Inorganic chemistry, 3403 Macromolecular and materials chemistry, 4003 Biomedical engineering, 4016 Materials engineering and 4019 Resources engineering and extractive metallurgy.
b) Nanotechnology is included in Groups 4103 Environmental biotechnology, 3106 Industrial biotechnology, 4018 Nanotechnology and 3206 Medical biotechnology.</skos:scopeNote>
