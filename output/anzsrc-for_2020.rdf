        <skos:definition xml:lang="en">This division covers the chemical sciences.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Indigenous chemical sciences are included in Division 45 Indigenous studies.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/3401"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/3402"/>
