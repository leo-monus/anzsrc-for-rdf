    <skos:topConceptOf rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
    <skos:definition xml:lang="en">This division covers mathematics, statistics, and mathematical aspects of the physical sciences.</skos:definition>
    <skos:scopeNote xml:lang="en">a) Indigenous mathematical sciences are included in Division 45 Indigenous studies.</skos:scopeNote>
    <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/4901"/>
