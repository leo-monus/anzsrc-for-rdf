        <skos:notation>45</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
        <skos:topConceptOf rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
        <skos:definition xml:lang="en">This division covers research that significantly:
. relates to Aboriginal and Torres Strait Islander, Māori, Pacific, and other Indigenous peoples, nations, communities, languages, places, cultures or knowledges and/or
. incorporates or utilises Indigenous methodologies/ways of knowing, theories, practice and/or
. is undertaken with or by these peoples, nations or communities.</skos:definition>
