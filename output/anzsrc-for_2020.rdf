  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-for/2020/3101">
    <skos:prefLabel xml:lang="en">Biochemistry and cell biology</skos:prefLabel>
    <skos:notation>3101</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-for/2020/31">
        <skos:prefLabel xml:lang="en">BIOLOGICAL SCIENCES</skos:prefLabel>
        <skos:notation>31</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
        <skos:topConceptOf rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
        <skos:definition xml:lang="en">This division covers biological sciences.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Indigenous biological sciences are included in Division 45 Indigenous studies.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/3101"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/3102"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/3103"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/3104"/>
