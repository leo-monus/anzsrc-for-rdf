        <skos:topConceptOf rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020"/>
        <skos:definition xml:lang="en">This division covers the physical sciences. It includes biological physics (other than human biophysics), medical physics and synchrotron and accelerator technologies.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Indigenous physical sciences are included in Division 45 Indigenous studies.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5101"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5102"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5103"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-for/2020/5104"/>
