        <skos:notation>180601</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/1806"/>
      </skos:Concept>
    </skos:narrower>
