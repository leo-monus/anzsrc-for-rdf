  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/130299">
    <skos:prefLabel xml:lang="en">Communication not elsewhere classified</skos:prefLabel>
    <skos:notation>130299</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/1302">
        <skos:prefLabel xml:lang="en">Communication</skos:prefLabel>
        <skos:notation>1302</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/13"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving understanding of the social and cultural contexts of communication.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Communications equipment is included in Group 2201 Communication technologies, systems and services.
b) Information and communication services, including media, library and information services are included in Division 22 Information and communication services.</skos:scopeNote>
