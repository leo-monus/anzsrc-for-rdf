      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/1704">
        <skos:prefLabel xml:lang="en">Energy transformation</skos:prefLabel>
        <skos:notation>1704</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/17"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards the transformation of energy resource minerals into heat, steam or electricity; and the conversion of coal, natural gas, oil shale and tar sands to liquid fuels. It includes hydrogen-based energy systems and fuel cells.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Transformation of renewable energy resources into heat, steam or electricity is included in Group 1708 Renewable energy.
b) Engines for use in transport other than internal hydrogen combustion engines are included in Group 2415 Transport equipment.</skos:scopeNote>
