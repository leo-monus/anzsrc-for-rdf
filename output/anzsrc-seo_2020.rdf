  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/180402">
    <skos:prefLabel xml:lang="en">Antarctic and Southern Ocean oceanic processes</skos:prefLabel>
    <skos:notation>180402</skos:notation>
