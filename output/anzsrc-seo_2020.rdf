  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/210201">
    <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander education engagement and attendance outcomes</skos:prefLabel>
