    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/1804">
        <skos:prefLabel xml:lang="en">Management of Antarctic and Southern Ocean environments</skos:prefLabel>
        <skos:notation>1804</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/18"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards the understanding and management of Antarctic and Southern Ocean environments. It includes: biodiversity; control of pests, diseases and exotic species; water quality and; rehabilitation or conservation.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Economic aspects of resource consumption are included in Group 1505 Microeconomics.
b) Economic aspects of the environment are included in Group 1599 Other economic framework.
c) Control and treatment of human diseases are included in Division 20 Health.
d) Environmental ethics is included in Group 1303 Ethics.
e) Rights to environmental and natural resources are included in Group 1902 Environmental policy, legislation and standards.</skos:scopeNote>
