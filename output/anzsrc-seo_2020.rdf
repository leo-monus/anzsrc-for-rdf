      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/150306">
        <skos:prefLabel xml:lang="en">Technological and organisational innovation</skos:prefLabel>
        <skos:notation>150306</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
