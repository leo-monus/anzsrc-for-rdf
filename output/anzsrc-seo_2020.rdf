        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/210499"/>
      </skos:Concept>
    </skos:broader>
  </skos:Concept>
  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/230115">
    <skos:prefLabel xml:lang="en">Youth services</skos:prefLabel>
    <skos:notation>230115</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2301">
        <skos:prefLabel xml:lang="en">Community services</skos:prefLabel>
        <skos:notation>2301</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/23"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards providing or delivering community and welfare services to individuals or to defined community groups such as the disabled, aged persons and single parents.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Development and provision of health services to specific population groups such as the aged persons, carers, children, men and women, indigenous communities, etc. and community health education is included in Division 20 Health.
b) Unpaid work and volunteering is included in Group 2305 Work and labour market.
c) Social ethics is included in Group 1303 Ethics.
d) Community services for Indigenous communities are included in Division 21 Indigenous.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/230101"/>
