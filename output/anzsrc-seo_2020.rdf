  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/170409">
    <skos:prefLabel xml:lang="en">Transformation of gas into fuels</skos:prefLabel>
    <skos:notation>170409</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
