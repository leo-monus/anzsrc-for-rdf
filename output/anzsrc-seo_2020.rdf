        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/120305"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/120306"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/120399"/>
      </skos:Concept>
