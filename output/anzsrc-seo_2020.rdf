        <skos:prefLabel xml:lang="en">Te whakatutukinga o te pūnaha hauora (Māori health system performance)</skos:prefLabel>
        <skos:notation>210703</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
