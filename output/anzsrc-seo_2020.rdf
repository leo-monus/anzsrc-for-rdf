  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2110">
    <skos:prefLabel xml:lang="en">Pacific Peoples education</skos:prefLabel>
    <skos:notation>2110</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/21"/>
    <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving understanding, provision and delivery of education relating to Pacific Peoples.</skos:definition>
    <skos:scopeNote xml:lang="en">a) Educational needs of non-Indigenous communities are included in Group 1601 Learner and learning.
b) Inclusive education related to non-Indigenous communities are included in Group 1602 Schools and learning environments.
c) The understanding and provision of education related to Aboriginal and Torres Strait Islander communities is included in Group 2102 Aboriginal and Torres Strait Islander education.
d) The understanding and provision of education related to Māori communities is included in Group 2106.</skos:scopeNote>
