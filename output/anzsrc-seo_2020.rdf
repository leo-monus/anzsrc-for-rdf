  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/240803">
    <skos:prefLabel xml:lang="en">Human pharmaceutical treatments</skos:prefLabel>
    <skos:notation>240803</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2408">
        <skos:prefLabel xml:lang="en">Human pharmaceutical products</skos:prefLabel>
        <skos:notation>2408</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/24"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards the manufacture of pharmaceutical products used in the prevention, diagnosis and treatment of human diseases.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Production of nutraceuticals is included in Group 2413 Processed food products and beverages (excl. dairy products).
b) Development of programs for the treatment of human diseases and disorders using human pharmaceutical products is included in the Division 20 Health.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/240801"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/240802"/>
