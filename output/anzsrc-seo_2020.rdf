  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/260602">
    <skos:prefLabel xml:lang="en">Cotton</skos:prefLabel>
    <skos:notation>260602</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2606">
        <skos:prefLabel xml:lang="en">Industrial crops</skos:prefLabel>
        <skos:notation>2606</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/26"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving the characteristics and growing of crops principally intended for industrial applications such as sugar cane, cotton, wine grapes, tobacco, hemp, cannabis and plants from which essential oils are extracted.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Table grapes are included in Group 2604 Horticultural crops.
b) Harvesting and packing of unprocessed industrial crops is included in Group 2604 Harvesting and packaging of plant products.
c) Management of environmental impacts from production of industrial crops is included in Group 2601 Environmentally sustainable plant production.
d) Manufacture of processed products from these plants is included in Division 24 Manufacturing.
e) Operation of irrigation systems is included in Group 1105 Water and waste services.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260601"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260602"/>
