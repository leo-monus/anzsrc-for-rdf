        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2111"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2112"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2199"/>
      </skos:Concept>
    </skos:broader>
    <skos:definition xml:lang="en">This group covers R&amp;D directed towards the provision and delivery of community and wellbeing services to Māori populations.</skos:definition>
    <skos:scopeNote xml:lang="en">a) Provision of community services to non-Indigenous populations is included in Group 2301 Community services.</skos:scopeNote>
