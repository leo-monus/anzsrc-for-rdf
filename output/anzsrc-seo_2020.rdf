      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2604">
        <skos:prefLabel xml:lang="en">Harvesting and packaging of plant products</skos:prefLabel>
        <skos:notation>2604</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/26"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving technologies, processes and methods used for harvesting, handling and packing of plant products, other than forest products.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Harvesting and transport of forest products is included in Group 2602 Forestry.
b) Improvement of the characteristics, propagation and growing of crops from which these plant products are obtained are included in Groups 2603 Grains and seeds, 2605 Horticultural crops and 2606 Industrial crops.
c) Production of biofuels from plant products is included in Group 1707 Processing of energy sources.
d) Manufacture of products other than biofuels from further processing of these plant products is included in Division 24 Manufacturing.
e) Transportation of plant products other than forest products is included in Division 27 Transport.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260401"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260402"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260403"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260404"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260405"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260406"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260499"/>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2605">
        <skos:prefLabel xml:lang="en">Horticultural crops</skos:prefLabel>
        <skos:notation>2605</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/26"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving the characteristics, propagation and growing of horticultural crops.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Wine grapes are included in Group 2606 Industrial crops.
b) Harvesting and packing of fresh fruits and vegetables is included in Group 2604 Harvesting and packaging of plant products.
c) Management of environmental impacts from production of horticultural crops is included in Group 2601 Environmentally sustainable plant production.
d) Manufacture of any processed products from horticultural plants is included in Division 24 Manufacturing.
e) Operation of irrigation systems is included in Group 1105 Water and waste services.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260501"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260502"/>
