    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2603">
        <skos:prefLabel xml:lang="en">Grains and seeds</skos:prefLabel>
        <skos:notation>2603</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/26"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving the characteristics of grains and seeds, including cereals grown either partially or entirely for use as fodder or feed grain.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Harvesting and packing of unprocessed grains and seeds is included in Group 2604 Harvesting and packaging of plant products.
b) Management of environmental impacts from production of grains and seeds is included in Group 2601 Environmentally sustainable plant production.
c) Manufacture of processed products from these plants is included in Division 24 Manufacturing.
d) Operation of irrigation systems is included in Group 1105 Water and waste services.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260301"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260302"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/260303"/>
