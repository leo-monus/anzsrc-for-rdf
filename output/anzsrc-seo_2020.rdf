        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/19"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards an understanding of natural hazards, their impact on lives, property and environments and the development of warning systems and control measures to minimise impacts from these hazards.</skos:definition>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/190401"/>
