  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/240799">
    <skos:prefLabel xml:lang="en">Fabricated metal products not elsewhere classified</skos:prefLabel>
    <skos:notation>240799</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2407">
