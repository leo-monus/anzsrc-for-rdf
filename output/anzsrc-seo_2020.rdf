    <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2304"/>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2305">
        <skos:prefLabel xml:lang="en">Work and labour market</skos:prefLabel>
        <skos:notation>2305</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/23"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards aspects of work and the labour market.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Management and productivity, including industrial relations, are included in Group 1503 Management and productivity.
b) Occupational health is included in Group 2004 Public health (excl. specific population health).
c) Workplace and organisational ethics is included in Group 1303 Ethics.</skos:scopeNote>
