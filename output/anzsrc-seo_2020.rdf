  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/160104">
    <skos:prefLabel xml:lang="en">Professional development and adult education</skos:prefLabel>
    <skos:notation>160104</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/1601">
        <skos:prefLabel xml:lang="en">Learner and learning</skos:prefLabel>
        <skos:notation>1601</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/16"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving the learning outcomes of individual learners.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Improvement of teaching and instruction techniques is included in Group 1603 Teaching and curriculum.
b) Curriculum improvement is included in Group 1603 Teaching and curriculum.
c) Improvement of school and educational institution learning environments is included in Group 1603 Teaching and curriculum.
d) Improvement of education and training systems is included in Group 1603 Teaching and curriculum.
e) Educational needs of Aboriginal and Torres Strait Islanders, Māori and Pacific Peoples are included in Groups 2102 Aboriginal and Torres Strait Islander education, 2106 Māori education and 2110 Pacific Peoples education.
f) Ethical issues such as business ethics, social ethics, environmental ethics are included in Group 1303 Ethics.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/160101"/>
