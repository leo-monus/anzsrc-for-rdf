        <skos:prefLabel xml:lang="en">Environmentally sustainable energy activities not elsewhere classified</skos:prefLabel>
        <skos:notation>170599</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/1705"/>
