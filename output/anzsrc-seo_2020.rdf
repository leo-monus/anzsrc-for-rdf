  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/210404">
    <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander knowledge</skos:prefLabel>
    <skos:notation>210404</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2104">
        <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander heritage and culture</skos:prefLabel>
        <skos:notation>2104</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/21"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards improving understanding and recognition of Aboriginal and Torres Strait Islander culture and heritage.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Understanding heritage related to non-Indigenous populations is included in Group 1304 Heritage.
b) Rights to environmental and natural resources is included in Group 1902 Environmental policy, legislation and standards.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/210401"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/210402"/>
