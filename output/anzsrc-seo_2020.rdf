    <skos:prefLabel xml:lang="en">Management of greenhouse gas emissions from information and communication services</skos:prefLabel>
    <skos:notation>190307</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/1903">
        <skos:prefLabel xml:lang="en">Mitigation of climate change</skos:prefLabel>
        <skos:notation>1903</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/19"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards the development of strategies to mitigate climate change.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Strategies relating to adaptation to climate change are included in Group 1901 Adaptation to climate change.
b) Understanding climate change and its effects are included in Group 1905 Understanding climate change.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/190301"/>
