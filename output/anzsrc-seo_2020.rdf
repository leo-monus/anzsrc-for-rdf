  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/241102">
    <skos:prefLabel xml:lang="en">Cotton ginning</skos:prefLabel>
    <skos:notation>241102</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2411">
        <skos:prefLabel xml:lang="en">Leather products, fibre processing and textiles</skos:prefLabel>
        <skos:notation>2411</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/24"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards the production of leather and textile products and fibre processing.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Productions of plants or animals from which raw materials for these manufactured products are obtained are included in Division 26 Plant production and plant primary products or Division 10 Animal production and animal primary products.</skos:scopeNote>
