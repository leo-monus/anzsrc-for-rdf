  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2105">
    <skos:prefLabel xml:lang="en">Ngā ratonga hapori Māori (Māori community services)</skos:prefLabel>
    <skos:notation>2105</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/21">
        <skos:prefLabel xml:lang="en">INDIGENOUS</skos:prefLabel>
        <skos:notation>21</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:topConceptOf rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:definition xml:lang="en">This division covers R&amp;D directed towards understanding Aboriginal and Torres Strait Islander, Māori, Pacific and other Indigenous peoples, nations, communities, languages, places, cultures or knowledges.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Understanding of non-Indigenous cultures is included in Division 13 Culture and society.
b) Improving education and training for non-Indigenous populations is included in Division 16 Education and training.
c) Health for non-Indigenous populations is included in Division 20 Health.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2101"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2102"/>
