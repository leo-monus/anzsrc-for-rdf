  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/150199">
    <skos:prefLabel xml:lang="en">International trade policy not elsewhere classified</skos:prefLabel>
    <skos:notation>150199</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/1501">
        <skos:prefLabel xml:lang="en">International trade policy</skos:prefLabel>
        <skos:notation>1501</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/15"/>
        <skos:definition xml:lang="en">This group covers R&amp;D directed towards understanding issues relating to international trade, including trade policy, assistance and protection and international agreements on trade.</skos:definition>
        <skos:scopeNote xml:lang="en">a) Efficiency, safety and utility of international transport of freight and passengers is included in Division 27 Transport.
b) Domestic trade is included in Group 1103 Property, business support services and trade.
c) International political economy, other than international trade, and international relations that do not relate to trade are included in Group 2303 International relations.
d) Environmental aspects of international trade are included in Group 1902 Environmental policy, legislation and standards.</skos:scopeNote>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/150101"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/150102"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/150103"/>
        <skos:narrower rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/150199"/>
      </skos:Concept>
    </skos:broader>
  </skos:Concept>
  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2103">
    <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander health</skos:prefLabel>
    <skos:notation>2103</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/21"/>
    <skos:definition xml:lang="en">This group covers R&amp;D directed towards the public health of Aboriginal and Torres Strait Islanders. It includes the study of social and cultural factors affecting the health of Aboriginal and Torres Strait Islanders and the delivery of health services to these communities.</skos:definition>
    <skos:scopeNote xml:lang="en">a) The diagnosis, prevention and treatment of clinical conditions for non-Indigenous communities is included in Group 2001 Clinical health.
b) Evaluation of health and support services and health policies for non-Indigenous communities is included in Group 2002 Evaluation of health and support services.
c) Provision of health and support services for non-Indigenous communities is included in Group 2003 Provision of health and support services.
d) Health as it pertains to the general population and non-Indigenous communities is included in Group 2004 Public health (excl. specific population health) and Group 2005 Specific population health (excl. Indigenous health).</skos:scopeNote>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/210301">
        <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander determinants of health</skos:prefLabel>
        <skos:notation>210301</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2103"/>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/210302">
        <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander health status and outcomes</skos:prefLabel>
        <skos:notation>210302</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2103"/>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/210303">
        <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander health system performance</skos:prefLabel>
        <skos:notation>210303</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2103"/>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/210399">
        <skos:prefLabel xml:lang="en">Aboriginal and Torres Strait Islander health not elsewhere classified</skos:prefLabel>
        <skos:notation>210399</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
        <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/2103"/>
      </skos:Concept>
    </skos:narrower>
  </skos:Concept>
  <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/2404">
    <skos:prefLabel xml:lang="en">Computer, electronic and communication equipment</skos:prefLabel>
    <skos:notation>2404</skos:notation>
    <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
    <skos:broader rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020/24"/>
    <skos:definition xml:lang="en">This group covers R&amp;D directed towards the manufacture of computer hardware and electronic equipment, including consumer electronic equipment.</skos:definition>
    <skos:scopeNote xml:lang="en">a) Whitewares, electrical appliances, machinery and equipment is included in Group 2412 Machinery and equipment.
b) Communication equipment is included in Group 2201 Communication technologies, systems and services.
c) Development of computer software and the provision of programming services are included in Group 2204 Information systems, technologies and services.</skos:scopeNote>
    <skos:narrower>
      <skos:Concept rdf:about="https://linked.data.gov.au/def/anzsrc-seo/2020/240401">
        <skos:prefLabel xml:lang="en">Computer and electronic office equipment (excl. communication equipment)</skos:prefLabel>
        <skos:notation>240401</skos:notation>
        <skos:inScheme rdf:resource="https://linked.data.gov.au/def/anzsrc-seo/2020"/>
